@model FornecedorModel

@{
    ViewData["Title"] = "Editar Fornecedor";
}

<div class="container mt-5">
    <h2 class="mb-4">Editar Fornecedor</h2>
    <form asp-controller="Cadastro" asp-action="Editar" method="post">
        <input type="hidden" asp-for="Id"/>

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" type="text" id="nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CNPJ" class="form-label"></label>
            <input asp-for="CNPJ" type="text" id="cnpj" class="form-control" placeholder="Somente números (14 dígitos)" />
            <span asp-validation-for="CNPJ" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Segmento" class="form-label"></label>
            <select asp-for="Segmento" id="segmento" class="form-select">
                <option value="">Selecione</option>
                <option value="Comércio">Comércio</option>
                <option value="Serviço">Serviço</option>
                <option value="Indústria">Indústria</option>
            </select>
            <span asp-validation-for="Segmento" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CEP" class="form-label"></label>
            <input asp-for="CEP" type="text" id="cep" class="form-control" placeholder="Somente números (8 dígitos)" />
            <span asp-validation-for="CEP" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Endereco" class="form-label">Endereço</label>
            <input asp-for="Endereco" type="text" id="endereco" class="form-control" />
            <span asp-validation-for="Endereco" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success ">Alterar</button>
        <button type="reset" class="btn btn-secondary">Limpar</button>
        <a class="btn btn-secondary" asp-controller="Cadastro" asp-action="Index" role="button">Voltar</a>

    </form>
</div>

