@model List<FornecedorModel>
@{

    ViewData["Title"] = "Lista de Fornecedores";
}
<div class="text-center">

    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
        <a class="btn btn-primary" role="button"asp-controller="Cadastro"asp-action="Criar">Adicionar novo Fornecedor</a>
    </div>
    <br />    
    <h2 class="text-center mb-4">Lista de Fornecedores</h2>
    <div class="container mt-4">
        <table class="table table-striped table-bordered align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Nome</th>
                    <th scope="col">CNPJ</th>
                    <th scope="col">Segmento</th>
                    <th scope="col">CEP</th>
                    <th scope="col">Endereço</th>
                    <th scope="col">Foto</th>
                    <th scope="col">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (FornecedorModel fornecedor in Model)
                    {
                        <tr>
                            <td>@fornecedor.Id</td>
                            <td>@fornecedor.Nome</td>
                            <td>@fornecedor.CNPJ</td>
                            <td>@fornecedor.Segmento</td>
                            <td>@fornecedor.CEP</td>
                            <td>@fornecedor.Endereco</td>
                            <td>
                               
                            </td>

                            <td>
                                <a role="button"
                                   asp-controller="Cadastro"
                                   asp-action="Editar"
                                   asp-route-id="@fornecedor.Id"
                                   class="btn btn-sm btn-primary">Editar</a>

                                <a role="button"
                                   asp-controller="Cadastro"
                                   asp-action="ApagarConfirmacao"
                                   asp-route-id="@fornecedor.Id"
                                   class="btn btn-sm btn-danger">Excluir</a>
                            </td>
                        </tr>
                    }
  
                } 
                else
                {
        
                    <tr>
                        <td colspan="8" class="text-center">Nenhum fornecedor cadastrado.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>


</div>

